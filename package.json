{
  "name": "my-app",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev:client": "vite client",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently \"npm run dev:client\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build client",
    "electron:build": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "build": {
    "appId": "com.yourname.app",
    "files": [
      "client/dist/**/*",
      "electron/**/*",
      "server/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
